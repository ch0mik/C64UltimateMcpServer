@host = http://localhost:8080

### 01. MCP initialize
# @name init
POST {{host}}/
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 1,
  "method": "initialize",
  "params": {
    "protocolVersion": "2025-11-05",
    "capabilities": {},
    "clientInfo": {
      "name": "http-smoke-client",
      "version": "1.0.0"
    }
  }
}

###
### 02. MCP initialized notification
POST {{host}}/
Content-Type: application/json
Accept: application/json, text/event-stream
Mcp-Session-Id: {{init.response.headers.Mcp-Session-Id}}

{
  "jsonrpc": "2.0",
  "method": "notifications/initialized"
}

###
### 03. Get prompt by backward-compatible alias
POST {{host}}/
Content-Type: application/json
Accept: application/json, text/event-stream
Mcp-Session-Id: {{init.response.headers.Mcp-Session-Id}}

{
  "jsonrpc": "2.0",
  "id": 4,
  "method": "prompts/get",
  "params": {
    "name": "c64_basic_program_prompt",
    "arguments": {
      "goal": "Create a simple sprite-free BASIC intro screen",
      "level": "beginner"
    }
  }
}

###
### 04. Get prompt by current prompt name
POST {{host}}/
Content-Type: application/json
Accept: application/json, text/event-stream
Mcp-Session-Id: {{init.response.headers.Mcp-Session-Id}}

{
  "jsonrpc": "2.0",
  "id": 5,
  "method": "prompts/get",
  "params": {
    "name": "basic-program",
    "arguments": {
    }
  }
}
